{
  "framework": "nextjs",
  "regions": ["bom1"],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fitpic.in" }],
      "destination": "https://www.fitpic.in/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
